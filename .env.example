# SigmaGPT environment template

# Backend AI proxy
PORT=5000
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_SMART=llama-3.3-70b-versatile
GROQ_MODEL_BALANCED=gemma2-9b-it

# Optional provider keys if you later swap the backend provider implementation
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Frontend config
VITE_API_BASE_URL=http://localhost:5000
VITE_DEFAULT_THEME=dark
VITE_ENABLE_VOICE_INPUT=true
VITE_ENABLE_THEME_RIPPLE=true